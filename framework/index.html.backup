<!-- ═══════════════════════════════════════
     SCRIPTS
     ═══════════════════════════════════════ -->
<script>
/* ── Nav on Scroll ── */
const nav = document.getElementById('nav');
const hero = document.getElementById('hero');
new IntersectionObserver(([e]) => {
  nav.classList.toggle('scrolled', !e.isIntersecting);
}).observe(hero);

/* ── Scroll Reveal ── */
const reveals = document.querySelectorAll('.reveal');
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      revealObs.unobserve(entry.target);
    }
  });
}, { threshold: 0.1 });
reveals.forEach(el => revealObs.observe(el));

/* ── Token Explorer ── */
const tabs   = document.querySelectorAll('.te-tab');
const slides = document.querySelectorAll('.te-slide');
const prog   = document.querySelector('.te-progress');
const arrows = document.getElementById('teArrows');
let current  = 0;

function goTo(i) {
  if (i < 0 || i >= slides.length) return;
  current = i;
  tabs.forEach(t => t.classList.toggle('active', +t.dataset.i === i));
  slides.forEach(s => {
    s.classList.remove('active');
    s.style.animation = 'none';
  });
  slides[i].offsetHeight; // reflow
  slides[i].classList.add('active');
  slides[i].style.animation = 'slideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1)';
  const nums = ['①', '②', '③', '④', '⑤', '⑥', '⑦', '⑧'];
  prog.textContent = nums[i] + ' of ⑧';

  // Scroll active tab into view
  tabs[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
}

tabs.forEach(tab => tab.addEventListener('click', () => goTo(+tab.dataset.i)));
document.getElementById('prevToken').addEventListener('click', () => goTo(current - 1));
document.getElementById('nextToken').addEventListener('click', () => goTo(current + 1));

// Keyboard nav
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowRight') goTo(current + 1);
  if (e.key === 'ArrowLeft')  goTo(current - 1);
});

// Show/hide arrows when explorer is in view
const explorerObs = new IntersectionObserver(([entry]) => {
  arrows.classList.toggle('show', entry.isIntersecting);
}, { threshold: 0.3 });
explorerObs.observe(document.getElementById('explorer'));

// Dimension cards link to explorer
document.querySelectorAll('.dim-card').forEach(el => {
  el.addEventListener('click', () => {
    const i = +el.dataset.token;
    document.getElementById('explorer').scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => goTo(i), 600);
  });
});

/* ══════════════════════════════════════
   INTERACTIVE "HOW IT WORKS" DEMO
   ══════════════════════════════════════ */
const scenarios = [
  {
    intent: '"What can I cook tonight?"',
    tokens: [
      { num: '①', name: 'Intent', value: 'Decide', rule: '<strong>Intent = Decide</strong> → Show actionable options only.' },
      { num: '②', name: 'Physical', value: 'Driving', rule: '<strong>Physical = Driving</strong> → Voice-only. Hands on wheel.' },
      { num: '③', name: 'Cognitive', value: 'Depleted', rule: '<strong>Cognitive = Depleted</strong> → Max 3 options. No comparisons.' },
      { num: '④', name: 'Social', value: 'Private', rule: '<strong>Social = Private</strong> → Show all details. Full prices.' },
      { num: '⑤', name: 'Priority', value: 'Speed first', rule: '<strong>Priority = Speed</strong> → Sort by cook time. No long recipes.' },
      { num: '⑥', name: 'Synchro', value: 'Confirm', rule: '<strong>Synchro = Confirm</strong> → AI suggests, ask before ordering.' },
      { num: '⑦', name: 'Form', value: 'Phone', rule: '<strong>Form = Phone</strong> → Lock screen recipe. Voice steps.' },
      { num: '⑧', name: 'Feasibility', value: '28min home', rule: '<strong>Feasibility = 28min, chicken + rice in fridge</strong> → Auto-order missing items.' }
    ],
    output: {
      title: 'Voice cooking dashboard',
      features: ['3 recipes under 28min', 'Voice steps', 'Auto-order items'],
      why: 'Just three things you can actually make tonight, with what you have.'
    }
  },
  {
    intent: '"It\'s raining."',
    tokens: [
      { num: '①', name: 'Intent', value: 'Adapt', rule: '<strong>Intent = Adapt</strong> → Restructure itinerary. Find indoor alternatives.' },
      { num: '②', name: 'Physical', value: 'Seated', rule: '<strong>Physical = Seated</strong> → Family is in restaurant. Both hands free.' },
      { num: '③', name: 'Cognitive', value: 'Alert', rule: '<strong>Cognitive = Alert</strong> → Process major change. Show comparisons.' },
      { num: '④', name: 'Social', value: 'Family', rule: '<strong>Social = Family</strong> → Parents see cost impact. Kids see adventures.' },
      { num: '⑤', name: 'Priority', value: 'Experience', rule: '<strong>Priority = Experience > Budget</strong> → Quality over cost.' },
      { num: '⑥', name: 'Synchro', value: 'Suggest', rule: '<strong>Synchro = Suggest</strong> → AI proposes changes. Family approves.' },
      { num: '⑦', name: 'Form', value: 'Phone + Map', rule: '<strong>Form = Phone + Map</strong> → New route + indoor venues.' },
      { num: '⑧', name: 'Feasibility', value: 'Kyoto, Day 3', rule: '<strong>Feasibility = Indoor spots near hotel, within budget</strong> → 10sec replanning.' }
    ],
    output: {
      title: 'Itinerary restructured instantly',
      features: ['Outdoor → Indoor swaps', 'Budget impact shown', 'New route calculated'],
      why: 'The entire plan reshapes in 10 seconds. No manual rebuilding. Adventure continues.'
    }
  },
  {
    intent: '"Winter shoes, not puffy inside."',
    tokens: [
      { num: '①', name: 'Intent', value: 'Explore → Buy', rule: '<strong>Intent = Explore → Buy</strong> → Browsing becomes decision mode.' },
      { num: '②', name: 'Physical', value: 'One hand then both', rule: '<strong>Physical = One hand (train) → Both hands (home)</strong> → Cards then grid.' },
      { num: '③', name: 'Cognitive', value: 'Baseline', rule: '<strong>Cognitive = Baseline</strong> → Full details. Multiple comparisons.' },
      { num: '④', name: 'Social', value: 'Public → Family', rule: '<strong>Social = Public → Family</strong> → Prices hidden from kid at home.' },
      { num: '⑤', name: 'Priority', value: 'Kid preference', rule: '<strong>Priority = What kid likes</strong> → Not brand rankings.' },
      { num: '⑥', name: 'Synchro', value: 'Suggest', rule: '<strong>Synchro = Suggest</strong> → AI narrows 300 to 3. Family chooses together.' },
      { num: '⑦', name: 'Form', value: 'Phone → remote + TV', rule: '<strong>Form = Phone becomes remote remote, TV shows grid</strong> → Kid points, parent selects.' },
      { num: '⑧', name: 'Feasibility', value: 'Black, waterproof, in stock', rule: '<strong>Feasibility = Size verified, delivery before weekend</strong> → Hide out-of-stock, puffy linings.' }
    ],
    output: {
      title: 'Multi-surface family shopping',
      features: ['3 curated shoes on TV', 'Phone as remote', 'Prices hidden from kid'],
      why: 'AI protects the moment of choosing together. Kid points. Parent confirms. Magic preserved.'
    }
  }
];

let activeScenario = 0;
let activeToken = -1;

function runDemo(scenarioIndex) {
  activeScenario = scenarioIndex;
  activeToken = -1;
  const s = scenarios[scenarioIndex];

  // Update scenario buttons
  document.querySelectorAll('.demo-scenario-btn').forEach(btn => {
    btn.classList.toggle('active', +btn.dataset.scenario === scenarioIndex);
  });

  // Reset all
  const intentEl = document.getElementById('demoIntent');
  const tokensEl = document.getElementById('demoTokens');
  const arrowEl = document.getElementById('demoArrow');
  const outputEl = document.getElementById('demoOutput');

  intentEl.classList.remove('show');
  arrowEl.classList.remove('show');
  outputEl.classList.remove('show');

  // Set intent text
  document.getElementById('demoIntentText').innerHTML = s.intent;

  // Build token cards
  tokensEl.innerHTML = s.tokens.map((t, i) => `
    <div class="demo-token" data-ti="${i}" style="transition-delay: ${0.6 + i * 0.1}s">
      <div class="demo-token-header">
        <span class="demo-token-num">${t.num}</span>
        <span class="demo-token-name">${t.name}</span>
      </div>
      <div class="demo-token-value">${t.value}</div>
      <div class="demo-token-detail">
        <div class="demo-token-rule">${t.rule}</div>
      </div>
    </div>
  `).join('');

  // Add click handlers
  tokensEl.querySelectorAll('.demo-token').forEach(el => {
    el.addEventListener('click', () => {
      const ti = +el.dataset.ti;
      if (activeToken === ti) {
        el.classList.remove('active');
        activeToken = -1;
      } else {
        tokensEl.querySelectorAll('.demo-token').forEach(e => e.classList.remove('active'));
        el.classList.add('active');
        activeToken = ti;
      }
    });
  });

  // Build output
  outputEl.innerHTML = `
    <div class="demo-output-label">Adaptive UI Output</div>
    <div class="demo-output-title">${s.output.title}</div>
    <div class="demo-output-features">
      ${s.output.features.map(f => `<span class="demo-output-feature">${f}</span>`).join('')}
    </div>
    <div class="demo-output-why">${s.output.why}</div>
  `;

  // Animate sequence
  setTimeout(() => intentEl.classList.add('show'), 100);
  setTimeout(() => {
    tokensEl.querySelectorAll('.demo-token').forEach((el, i) => {
      setTimeout(() => el.classList.add('show'), i * 100);
    });
  }, 500);
  setTimeout(() => arrowEl.classList.add('show'), 500 + s.tokens.length * 100 + 200);
  setTimeout(() => outputEl.classList.add('show'), 500 + s.tokens.length * 100 + 500);
}

// Init
document.querySelectorAll('.demo-scenario-btn').forEach(btn => {
  btn.addEventListener('click', () => runDemo(+btn.dataset.scenario));
});
document.getElementById('demoReplay').addEventListener('click', () => runDemo(activeScenario));

// Auto-run when section comes into view
const demoObs = new IntersectionObserver(([entry]) => {
  if (entry.isIntersecting) {
    runDemo(0);
    demoObs.unobserve(entry.target);
  }
}, { threshold: 0.2 });
demoObs.observe(document.getElementById('systems'));
</script>

</body>
</html>
